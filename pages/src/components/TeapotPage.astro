<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>418 - I'm a Teapot | Purus</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    :root {
      --sl-color-white: hsl(0, 0%, 100%);
      --sl-color-black: hsl(224, 10%, 10%);
      --sl-color-gray-1: hsl(224, 20%, 94%);
      --sl-color-gray-2: hsl(224, 6%, 77%);
      --sl-color-gray-3: hsl(224, 6%, 56%);
      --sl-color-gray-5: hsl(224, 10%, 23%);
      --sl-color-gray-6: hsl(224, 14%, 16%);
      --sl-color-accent: hsl(224, 100%, 60%);
      --sl-color-accent-high: hsl(224, 100%, 85%);
      --sl-font: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
      --sl-font-mono: ui-monospace, 'Cascadia Code', 'Fira Code', Menlo, Consolas, monospace;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      background: var(--sl-color-black);
      color: var(--sl-color-gray-1);
      font-family: var(--sl-font);
      font-size: 1rem;
      line-height: 1.8;
    }

    header {
      border-bottom: 1px solid var(--sl-color-gray-5);
      background: var(--sl-color-gray-6);
      padding: 0.75rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    header img {
      height: 1.5rem;
      width: auto;
    }

    header .site-title {
      font-size: 1.125rem;
      font-weight: 600;
      color: var(--sl-color-white);
      text-decoration: none;
    }

    main {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .container {
      text-align: center;
      max-width: 40rem;
    }

    .teapot {
      font-size: 6rem;
      margin-bottom: 1rem;
      animation: wobble 2s ease-in-out infinite;
    }

    @keyframes wobble {
      0%, 100% { transform: rotate(0deg); }
      25% { transform: rotate(-5deg); }
      75% { transform: rotate(5deg); }
    }

    .status {
      font-size: 2.1875rem;
      font-weight: 600;
      color: var(--sl-color-white);
      margin-bottom: 0.25rem;
    }

    .message {
      font-size: 1.25rem;
      color: var(--sl-color-gray-2);
      margin-bottom: 2rem;
    }

    .code {
      background: var(--sl-color-gray-6);
      border: 1px solid var(--sl-color-gray-5);
      border-radius: 0.5rem;
      padding: 1rem 1.5rem;
      margin-bottom: 2rem;
      font-family: var(--sl-font-mono);
      font-size: 0.875rem;
      color: var(--sl-color-gray-1);
      text-align: left;
      display: inline-block;
    }

    .code .keyword {
      color: hsl(2, 100%, 72%);
    }

    .code .string {
      color: var(--sl-color-accent-high);
    }

    .code .comment {
      color: var(--sl-color-gray-3);
    }

    .home-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1.25rem;
      background: var(--sl-color-accent);
      color: var(--sl-color-black);
      text-decoration: none;
      border-radius: 999rem;
      font-size: 0.875rem;
      font-weight: 500;
      transition: background 0.2s;
    }

    .home-link:hover {
      background: var(--sl-color-accent-high);
      color: var(--sl-color-black);
    }

    @media (prefers-color-scheme: light) {
      :root {
        --sl-color-black: hsl(224, 19%, 97%);
        --sl-color-white: hsl(224, 10%, 10%);
        --sl-color-gray-1: hsl(224, 14%, 16%);
        --sl-color-gray-2: hsl(224, 10%, 23%);
        --sl-color-gray-3: hsl(224, 7%, 36%);
        --sl-color-gray-5: hsl(224, 6%, 77%);
        --sl-color-gray-6: hsl(224, 20%, 94%);
        --sl-color-accent: hsl(234, 90%, 60%);
        --sl-color-accent-high: hsl(234, 80%, 30%);
      }

      .code .keyword {
        color: hsl(2, 80%, 45%);
      }
    }
  </style>
</head>
<body>
  <header>
    <img src="/favicon.svg" alt="Purus" />
    <a class="site-title" href="/">Purus</a>
  </header>
  <main>
    <div class="container">
      <div class="teapot">🫖</div>
      <div class="status">418</div>
      <div class="message">I'm a Teapot</div>
      <div class="code">
        <span class="comment">-- I'm a teapot, not a server</span><br />
        <span class="keyword">throw</span> <span class="keyword">new</span> Error[<span class="string">///I can only brew tea///</span>]
      </div>
      <br />
      <a class="home-link" href="/">&#8592; Go Home</a>
    </div>
  </main>
</body>
</html>
